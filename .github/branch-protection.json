# Branch Protection — main
#
# Apply these settings to the `main` branch via:
# GitHub repo → Settings → Branches → Add rule
#
# Or use the GitHub CLI:
#   gh api repos/Cameroon-Developer-Network/zenvra/branches/main/protection \
#     --method PUT --input .github/branch-protection.json
#
# The JSON equivalent is below for reference.

{
  "required_status_checks": {
    "strict": true,
    "contexts": [
      "Rust (fmt · clippy · test)",
      "Frontend (lint · typecheck · build)",
      "VS Code Extension (lint · compile)"
    ]
  },
  "enforce_admins": false,
  "required_pull_request_reviews": {
    "required_approving_review_count": 1,
    "dismiss_stale_reviews": true,
    "require_code_owner_reviews": false
  },
  "restrictions": null,
  "allow_force_pushes": false,
  "allow_deletions": false,
  "required_linear_history": true,
  "required_conversation_resolution": true
}
